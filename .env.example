# Copy to .env and fill in. NEVER put real keys in THIS file (.env.example is committed to git).
# Put real values in .env only (which is gitignored).

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, keep secret

# --- News APIs ---
FINNHUB_API_KEY=your-finnhub-key
MTNEWSWIRES_API_KEY=your-mtnewswires-key

# --- Alpaca (US market data; paper keys work fine) ---
ALPACA_API_KEY=your-alpaca-key-id
ALPACA_API_SECRET=your-alpaca-secret-key

# --- IBKR (used by IBC config on the VM, not committed) ---
IBKR_TRADING_MODE=paper
IBKR_API_HOST=127.0.0.1
IBKR_API_PORT=4002
